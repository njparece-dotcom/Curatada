DATABASE_URL=postgresql://quallection:quallection@localhost:5432/quallection
POSTGRES_USER=quallection
POSTGRES_PASSWORD=quallection
POSTGRES_DB=quallection

# NextAuth — required
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3000

# Anthropic — required for valuations and pursuit search
ANTHROPIC_API_KEY=

# Cron container shared secret — must match between the app and cron containers.
# Generate with `openssl rand -hex 32`. Without it, /api/pursuits/run-search can
# only be invoked by a signed-in browser session.
CRON_SECRET=

# Management API — bearer token for the cross-app dashboard's /api/mgmt/v1/*
# endpoints. Generate with `openssl rand -base64 32`. Leave blank to disable
# the mgmt API entirely (every endpoint returns 503).
MGMT_API_TOKEN=

# Set to 1 to reject mgmt API calls that came through the public Railway edge
# (any request with an X-Forwarded-For header). Pairs with private-network
# calls via <service>.railway.internal. Recommended in production once the
# dashboard is set up to call internally.
MGMT_REQUIRE_INTERNAL=0

# Cloudflare R2 — object storage for uploaded images. When all four vars are
# set, the app writes new uploads to R2 and serves them via short-lived
# presigned URLs. When unset, /api/upload writes to public/uploads/ on local
# disk (useful for `npm run dev` without provisioning a bucket).
#
# To set up in Cloudflare: R2 → Create bucket → API tokens → "Object Read & Write".
# Bucket should be private (the app generates presigned URLs per view).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
